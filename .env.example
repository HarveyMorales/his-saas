# ============================================================
# HIS SaaS — Variables de entorno
# Copiar este archivo como .env.local y completar los valores
# NUNCA subir .env.local al repositorio
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://fxgnoexdeacuwezcpqpo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # Settings → API → anon public
SUPABASE_SERVICE_ROLE_KEY=              # Settings → API → service_role (SECRETO)

# ── Base de datos (Prisma) ────────────────────────────────────
# Dashboard → Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.fxgnoexdeacuwezcpqpo:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Conexión directa (para migraciones — Session pooler puerto 5432)
DIRECT_URL=postgresql://postgres.fxgnoexdeacuwezcpqpo:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# ── App ───────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                        # openssl rand -base64 32

# ── AFIP (futuro) ─────────────────────────────────────────────
AFIP_CERT=
AFIP_KEY=
AFIP_CUIT=

# ── WhatsApp Business API (futuro) ───────────────────────────
WA_TOKEN=
WA_PHONE_ID=
WA_BA_ID=
